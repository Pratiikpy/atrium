# Atrium agents env config, copy to .env on the droplet, fill in.
# .env is gitignored at the repo root and must NEVER be committed.

# Codex API gateway, already live on Cloudflare.
CODEX_URL=https://codex-staging.atrium.fi

# Per-instrument config required by Haruspex + Auspex.
# Instrument IDs come from Plinth's instrument registry; pick any deployed
# venue's symbol once the venue adapters are live (Stylus blocker).
HARUSPEX_INSTRUMENT_ID=HL-HIP3-BTC-USDC
AUSPEX_INSTRUMENT_ID=HL-HIP3-ETH-USDC

# Optional: Praetor RPC URL override (defaults to public node)
ARBITRUM_SEPOLIA_RPC=https://arbitrum-sepolia.publicnode.com

# Logging: trace | debug | info | warn | error
RUST_LOG=info
