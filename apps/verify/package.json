{
  "name": "@atrium/verify",
  "version": "0.1.0",
  "private": true,
  "description": "Atrium Verifier Mode, the judge-facing scripted demo surface",
  "scripts": {
    "dev": "next dev --turbo --port 3000",
    "prebuild": "node ../../scripts/download-fonts.mjs && node scripts/build-audit-findings.mjs && node scripts/build-runbooks.mjs",
    "build": "next build",
    "audit-findings:build": "node scripts/build-audit-findings.mjs",
    "runbooks:build": "node scripts/build-runbooks.mjs",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=200",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "clean": "rm -rf .next out node_modules/.cache"
  },
  "dependencies": {
    "@coinbase/onchainkit": "^0.35.0",
    "@sentry/nextjs": "^10.53.1",
    "@tanstack/react-query": "^5.59.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.4",
    "clsx": "^2.1.0",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.451.0",
    "next": "^16.2.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "siwe": "^2.3.2",
    "tailwind-merge": "^2.5.0",
    "viem": "^2.21.0",
    "wagmi": "^2.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.0.0-beta",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.0.3",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0-beta",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
