# Build sandbox only sources the contracts/ + scripts/ tree.
# Keep image build contexts under 50MB so the daemon transfer stays under
# a second instead of several minutes.

node_modules/
**/node_modules/
.pnpm-store/

# Rust + Stylus
target/
**/target/
**/*.rs.bk
Cargo.lock
!Cargo.lock
.cargo/

# Foundry
out/
**/out/
cache/
**/cache/
broadcast/
foundry-out/
.forge-cache/

# Next.js / build artefacts
.next/
**/.next/
dist/
build/
.turbo/
*.tsbuildinfo

# Subgraph
generated/
**/generated/
**/build/

# Python
__pycache__/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Local reference clones (huge, never needed in build)
resources/

# Local caches we don't ship
.playwright-mcp/
.forge-cache/

# Test fixtures + coverage
coverage/
.nyc_output/

