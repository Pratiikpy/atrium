{
  "version": 2,
  "buildCommand": "echo 'no build'",
  "outputDirectory": "api",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 12 * * *"
    }
  ],
  "functions": {
    "api/cron.ts": {
      "maxDuration": 60
    }
  }
}
