# Codex service environment variables
# Managed via Doppler (atrium-staging / atrium-prod 'codex' configs)

# x402 payment recipient address — a Coffer-deposit-derived address
# controlled by Praetor multisig. MUST be set before production deploy.
CODEX_PAY_TO_ADDRESS=

# Scribe subgraph URL
SCRIBE_URL=

# Sentry DSN (optional — service runs without it)
SENTRY_DSN=

# Upstash Redis URL + token for rate limiting / idempotency
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
