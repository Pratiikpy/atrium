# Atrium .gitignore — keep the repo clean

# Node + pnpm
node_modules/
.pnpm-store/
.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo

# Rust + Stylus
target/
**/*.rs.bk
Cargo.lock
!**/Cargo.lock
.cargo/

# Foundry
out/
cache/
broadcast/
foundry-out/

# Subgraph
generated/
build/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Env + secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
secrets/
keys/

# Local notes — never commit
outreach/targets-private.md
notes/
*.local.md
.scratch/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# CI artifacts
coverage/
*.lcov
.nyc_output/

# Misc
*.log
.cache/

# External reference clones (re-clonable, large, mixed-license. See RESOURCES.md
# for the list and what each is for. The 10 build-deps below are tracked as
# git submodules so CI can resolve foundry imports; the others stay local-only.
resources/
!resources/openzeppelin-contracts/
!resources/account-abstraction/
!resources/chainlink-brownie-contracts/
!resources/pyth-crosschain/
!resources/erc-8004-contracts/
!resources/aave-v3-core/
!resources/pendle-core-v2-public/
!resources/hyperliquid-contracts/
!resources/x402/
!resources/trustless-agents-erc-ri/

# Local caches we don't ship
.forge-cache/
.playwright-mcp/

# Founder personal notes + buildathon TOS PDFs, keep off-repo
my convo with one ai agent.txt
read this.txt
think_data.md
*.jpeg
*.jpg
*.png
!apps/verify/public/**/*.png
!apps/verify/public/**/*.jpg
!desing/**/*.png
!desing/**/*.jpg
london_version_open_house_buildathon_terms___conditions.pdf
openhouse_london_tc.pdf
atrium-site-tokens.json

# Audit reports were generated by an audit session, commit them since they
