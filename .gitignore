# Atrium .gitignore — keep the repo clean

# Node + pnpm
node_modules/
.pnpm-store/
.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo

# Rust + Stylus
target/
**/*.rs.bk
Cargo.lock
!**/Cargo.lock
.cargo/

# Foundry
out/
cache/
broadcast/
foundry-out/

# Subgraph
generated/
build/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Env + secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
secrets/
keys/

# Local notes — never commit
outreach/targets-private.md
notes/
*.local.md
.scratch/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# CI artifacts
coverage/
*.lcov
.nyc_output/

# Misc
*.log
.cache/

# External reference clones (re-clonable, large, mixed-license. See RESOURCES.md
# for the list and what each is for. The 10 build-deps below are tracked as
# git submodules so CI can resolve foundry imports; the others stay local-only.
resources/
!resources/openzeppelin-contracts/
!resources/account-abstraction/
!resources/chainlink-brownie-contracts/
!resources/pyth-crosschain/
!resources/erc-8004-contracts/
!resources/aave-v3-core/
!resources/pendle-core-v2-public/
!resources/hyperliquid-contracts/
!resources/x402/
!resources/trustless-agents-erc-ri/

# Local caches we don't ship
.forge-cache/
.playwright-mcp/

# Claude Code runtime state — settings + cron locks never go public.
# Project-wide team rules under .claude/rules/ DO ship (they define the
# team's coding standards). Only the runtime cruft is excluded.
.claude/scheduled_tasks*
.claude/settings*
.claude/projects/

# Internal ops scratch — kept local for the founder team, not on
# public github. Re-add to tracking only after stripping internal
# paths / outreach names per .claude/rules/git.md "Public repo
# readiness" + writing.md "Claims discipline".
human_left.md
codex plan.md
# Internal team conventions for the AI-assisted dev workflow.
# Kept LOCAL; the agent reads it via the working directory but it
# doesn't belong on the public github surface (named after the AI
# assistant + contains internal-only directives).
CLAUDE.md
# Buildathon-specific framing files. The product exists past Day 17;
# these are scaffolding for the one event and shouldn't read as
# permanent product collateral.
JUDGE_ONE_PAGER.md
LAUNCH_READY.md
# Self-judging audit files — internal, signed off, no longer useful
# as public-facing. The current audit lives under audits/ which is
# tracked and dated. Old root-level AUDIT_*.md are scratch.
AUDIT_*.md

# Founder personal notes + buildathon TOS PDFs, keep off-repo
my convo with one ai agent.txt
read this.txt
think_data.md
*.jpeg
*.jpg
*.png
!apps/verify/public/**/*.png
!apps/verify/public/**/*.jpg
!desing/**/*.png
!desing/**/*.jpg
london_version_open_house_buildathon_terms___conditions.pdf
openhouse_london_tc.pdf
atrium-site-tokens.json

# Audit reports were generated by an audit session, commit them since they
# document the state of the repo.
