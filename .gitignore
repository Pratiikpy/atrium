# Atrium .gitignore — keep the repo clean

# Node + pnpm
node_modules/
.pnpm-store/
.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo

# Rust + Stylus
target/
**/*.rs.bk
Cargo.lock
!**/Cargo.lock
.cargo/

# Foundry
out/
cache/
broadcast/
foundry-out/

# Subgraph
generated/
build/

# Verify app build-time generated data: committed so dev works without a
# prebuild, regenerated by scripts/build-runbooks.mjs on each build. The
# blanket `generated/` rule above is for the subgraph; this carves the
# verify-app data back in so regenerations are tracked, not silently stale.
!apps/verify/src/lib/generated/
!apps/verify/src/lib/generated/runbooks.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Env + secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
secrets/
keys/

# Local notes — never commit
outreach/targets-private.md
notes/
*.local.md
.scratch/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# CI artifacts
coverage/
*.lcov
.nyc_output/

# Misc
*.log
.cache/

# External reference clones (re-clonable, large, mixed-license. See RESOURCES.md
# for the list and what each is for. The 10 build-deps below are tracked as
# git submodules so CI can resolve foundry imports; the others stay local-only.
resources/
!resources/openzeppelin-contracts/
!resources/account-abstraction/
!resources/chainlink-brownie-contracts/
!resources/pyth-crosschain/
!resources/erc-8004-contracts/
!resources/aave-v3-core/
!resources/pendle-core-v2-public/
!resources/hyperliquid-contracts/
!resources/x402/
!resources/trustless-agents-erc-ri/

# Local caches we don't ship
.forge-cache/
.playwright-mcp/

# Local IDE and editor workspace configurations
.claude/

# Internal ops scratch — kept local for the founder team, not on
# public github. Re-add to tracking only after stripping internal
# paths / outreach names per docs/conventions/git.md "Public repo
# readiness" + writing.md "Claims discipline".
human_left.md
codex plan.md
atrium_goal_audit_prompt.md
# Local development-environment conventions
CLAUDE.md
# Buildathon-specific framing files. The product exists past Day 17;
# these are scaffolding for the one event and shouldn't read as
# permanent product collateral.
JUDGE_ONE_PAGER.md
LAUNCH_READY.md
# Self-judging audit files — internal, signed off, no longer useful
# as public-facing. The current audit lives under audits/ which is
# tracked and dated. Old root-level AUDIT_*.md are scratch.
AUDIT_*.md

# Long-form internal product + engineering docs. Serious product repos
# don't publish their PRD, full architecture spec, or roadmap — these
# are kept off-github (Notion / Drive). Local copies remain at the
# names below for the team to reference; the public docs/ folder
# keeps only what a real product publishes.
docs/architecture-internal.md
docs/prd-internal.md
docs/full-flow-design-internal.md
docs/12-month-roadmap-internal.md
docs/stylus-migration-internal.md
docs/AUDIT_FINDINGS.md
docs/LAUNCH_READINESS.md
docs/MONTHS_2_TO_12_BLUEPRINT.md
docs/MONTH_01_AUDIT.md
docs/ROADMAP.md
docs/kani-baseline.txt

# Internal audit scratch — Auditor A through H letter-coded reviews,
# month-N half-baked sweeps. Kept off-github; current public audit is
# audits/2026-05-25-contract-quality-audit.md.
audits/MONTH12_AUDIT_PLAN.md
audits/month-*.md

# Internal release notes with phase letters (alpha/beta/zeta/eta/theta)
# in filenames. Vocabulary outsiders don't have; kept local for team
# reference but not public.
tripwires/

# Demo rehearsal package — judge runbook, fault checklist, Loom
# outline. Operationally useful for the team but reads as buildathon
# scaffolding to an outsider.
rehearsals/

# Internal ops scripts — outreach templates, social announcement
# drafts, code4rena submission pack, legal-consult questions, launch
# runbook. All team-internal.
ops/LAUNCH_RUNBOOK.md
ops/code4rena-submission-pack.md
ops/legal-consult-questions.md
ops/social-announcements.md
ops/rehearsal-script.md
ops/outreach/

# Founder personal notes + buildathon TOS PDFs, keep off-repo
*convo*.txt
read this.txt
think_data.md
*.jpeg
*.jpg
*.png
!apps/verify/public/**/*.png
!apps/verify/public/**/*.jpg

# Design source folder — Figma-Make HTML exports + extracted fonts and
# JS assets. Design source lives in Figma; only final brand assets ship
# under apps/verify/public/brand/. The local design/ folder is the team's
# reference, not part of the public product surface.
design/

# Self-hosted fonts — downloaded at build time by scripts/download-fonts.mjs.
# Not committed to avoid large binaries in git.
apps/verify/public/fonts/*.woff2

london_version_open_house_buildathon_terms___conditions.pdf
openhouse_london_tc.pdf
atrium-site-tokens.json

# Audit reports were generated by an audit session, commit them since they
# document the state of the repo.
*.stackdump
.e2e-test-key.json

# Internal planning / audit / readiness docs (kept local, out of the public repo)
BUILD_PLAN.md
DO_NOW_PLAN.md
FEATURE_COMPLETION.md
FOUNDER_ACTIONS.md
PRODUCT_GAP_AUDIT.md
QA_LAUNCH_READINESS.md
map.md
docs/MASTER_PLAN.md
docs/plan-tracker.md
docs/FOUNDER-RUNBOOK.md
