# Atrium environment variables — copy to .env and fill in
# .env is gitignored. Never commit a real .env.

# ──────────────────────────────────────────────────────────────────────
# RPC + chain
# ──────────────────────────────────────────────────────────────────────
# RPC URLs (public free tiers work for testnet). Also accepted by the
# verify-app at runtime as ARBITRUM_SEPOLIA_RPC (no _URL suffix).
ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia.publicnode.com
ARBITRUM_SEPOLIA_RPC=https://arbitrum-sepolia.publicnode.com
ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
POLYGON_AMOY_RPC_URL=https://polygon-amoy.publicnode.com
# Robinhood Chain RPC — pending RH SDK release.
RH_CHAIN_RPC=

# Etherscan / Arbiscan (free API key from arbiscan.io)
ARBISCAN_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# Deployer + multisig
# ──────────────────────────────────────────────────────────────────────
# Deployer key — Hardhat/Anvil default for local fork dev only. Carved
# out by .gitleaksignore. NEVER use this against a network with real
# funds. For testnet deploys use a dedicated EOA + wipe after each use
# per the 2026-05-24 incident discipline.
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Praetor multisig address (Gnosis Safe on Arbitrum Sepolia). Year-1 is
# the deployer EOA; Phase η.4 migration switches to a 3-of-5 Safe.
PRAETOR_MULTISIG_ADDRESS=
# Praetor multisig SIGNING key — used by services that need to submit
# direct praetor txs (Sumsub callback → Edict.assignTier, etc.). Until
# the 3-of-5 Safe ceremony lands, this is the deployer EOA. After:
# rotate to a multisig-signer key.
PRAETOR_MULTISIG_KEY=

# ──────────────────────────────────────────────────────────────────────
# Pimlico + Postern (account abstraction)
# ──────────────────────────────────────────────────────────────────────
PIMLICO_API_KEY=
PIMLICO_RPC_URL=

# ──────────────────────────────────────────────────────────────────────
# Codex API (x402 + HMAC)
# ──────────────────────────────────────────────────────────────────────
# Coinbase x402 facilitator
COINBASE_X402_API_URL=https://facilitator.coinbase.com/x402
COINBASE_X402_API_KEY=

# Codex response signing
CODEX_HMAC_KEY=
CODEX_KEY_ID=v1

# x402 payment routing (Phase theta audit 2026-05-25: must NOT default
# to the deployer EOA — that key leaked. Set to the multisig recipient
# address. Leave blank to surface 'pay_to_not_configured' (503) loudly.)
CODEX_PAY_TO_ADDRESS=
CODEX_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
CODEX_MIN_PAYMENT_USDC_WEI=1000000

# Codex Upstash Redis (Vercel deploy uses these for x402 replay-dedup
# + idempotency. Without them the Vercel deploy falls back to per-
# instance inMemoryDB — dedup is NOT durable.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Codex backend DB (used by alt deploy paths)
DATABASE_URL=postgres://atrium:atrium@localhost:5432/atrium

# ──────────────────────────────────────────────────────────────────────
# Notifier service
# ──────────────────────────────────────────────────────────────────────
# Internal Bearer for the prefs API → notifier handshake.
ATRIUM_INTERNAL_KEY=
NOTIFIER_INTERNAL_KEY=
# Vercel KV REST endpoint for notifier last-block cursor
ATRIUM_KV_REST_URL=
ATRIUM_KV_REST_TOKEN=
NOTIFIER_FROM_BLOCK=0
# Scribe subgraph URL the notifier reads alerts from
SCRIBE_URL=
# Prefs API URL the notifier posts to. Typically
# https://verify.atrium.fi/api/settings/notifications
PREFS_API_URL=

# ──────────────────────────────────────────────────────────────────────
# Lantern attestor
# ──────────────────────────────────────────────────────────────────────
LANTERN_KEY_PATH=./secrets/lantern.key.enc
LANTERN_KEY_PASSPHRASE=

# ──────────────────────────────────────────────────────────────────────
# Sumsub KYC webhook
# ──────────────────────────────────────────────────────────────────────
# Webhook secret from Sumsub dashboard. Without it the route returns
# 503 sumsub_not_configured.
SUMSUB_WEBHOOK_SECRET=
# Edict contract address — where assignTier gets called on GREEN reviews.
EDICT_CONTRACT_ADDR=

# ──────────────────────────────────────────────────────────────────────
# Chaos drill (Verifier Mode step 4)
# ──────────────────────────────────────────────────────────────────────
# Dedicated EOA for chaos drills — NOT the deployer key. Must have
# multisig privileges on Plinth/Coffer/Vigil to pause/unpause. The
# Origin allowlist + per-IP rate-limit in /api/chaos/* gate the
# publicly-callable surface.
CHAOS_PRIVATE_KEY=
# Demo "keeper to mark missed" address for the keeper_offline fault.
# Leave blank to use the chaos signer's own address.
CHAOS_DEMO_KEEPER=

# ──────────────────────────────────────────────────────────────────────
# Multi-tenant default
# ──────────────────────────────────────────────────────────────────────
# Wallet address used as the default "demo wallet" when no ?wallet=
# query param is present on /api/* portfolio routes. Production should
# leave this unset so anonymous requests render the empty state.
DEMO_WALLET_ADDRESS=

# ──────────────────────────────────────────────────────────────────────
# The Graph + agents
# ──────────────────────────────────────────────────────────────────────
GRAPH_STUDIO_DEPLOY_KEY=
FLY_API_TOKEN=
# Vercel cron-only auth for agent ticks
CRON_SECRET=
# Per-agent address (production: each agent has its own session-key EOA
# bound to a registered Sigil mandate).
AGENT_AUGUR_ADDRESS=
AGENT_HARUSPEX_ADDRESS=
AGENT_AUSPEX_ADDRESS=

# ──────────────────────────────────────────────────────────────────────
# Public-side (NEXT_PUBLIC_*) — exposed to the browser bundle
# ──────────────────────────────────────────────────────────────────────
# Override USDC address for the testnet-token constants.
NEXT_PUBLIC_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
