# Atrium environment variables — copy to .env and fill in
# .env is gitignored. Never commit a real .env.

# RPC URLs (public free tiers work for testnet)
ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia.publicnode.com
ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
POLYGON_AMOY_RPC_URL=https://polygon-amoy.publicnode.com

# Etherscan / Arbiscan (free API key from arbiscan.io)
ARBISCAN_API_KEY=

# Deployer key — for local development only, never use a real key here
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Praetor multisig address (Gnosis Safe on Arbitrum Sepolia)
PRAETOR_MULTISIG_ADDRESS=

# Pimlico bundler + paymaster
PIMLICO_API_KEY=
PIMLICO_RPC_URL=

# Coinbase x402 facilitator
COINBASE_X402_API_URL=https://facilitator.coinbase.com/x402
COINBASE_X402_API_KEY=

# The Graph hosted service
GRAPH_STUDIO_DEPLOY_KEY=

# Codex backend signing key
CODEX_HMAC_KEY=
CODEX_KEY_ID=v1

# Lantern attestor key (encrypted at rest)
LANTERN_KEY_PATH=./secrets/lantern.key.enc
LANTERN_KEY_PASSPHRASE=

# Fly.io agents
FLY_API_TOKEN=

# Database (Codex backend)
DATABASE_URL=postgres://atrium:atrium@localhost:5432/atrium
