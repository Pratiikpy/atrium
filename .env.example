# Atrium environment variables. Copy to `.env` (and apps/verify/.env.local for
# the Next app), then fill in. `.env` and `.env.local` are gitignored: never
# commit a real one. Quick local setup: `node scripts/setup-local-env.mjs`
# generates the internal secrets and fills the public values for you.
#
# Legend:  [public]  safe, known value (a default is provided)
#          [secret]  get it from the named service; keep it out of git
#          [genned]  a random string you invent (setup-local-env.mjs makes it)
#          [optional] feature degrades to an honest disabled state if unset
#
# The verify-app reads these from apps/verify/.env.local; scripts + services
# read them from the repo-root .env. Vars used by both must hold the same value.

# ======================================================================
# RPC + chain                                                   [public]
# ======================================================================
# Public free tiers are fine for testnet. The verify-app also accepts the
# no-suffix forms (ARBITRUM_SEPOLIA_RPC, NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC).
ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia.publicnode.com
ARBITRUM_SEPOLIA_RPC=https://arbitrum-sepolia.publicnode.com
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://arbitrum-sepolia.publicnode.com
ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
POLYGON_AMOY_RPC_URL=https://polygon-amoy.publicnode.com
# Robinhood Chain testnet (Arbitrum Orbit L2, chainId 46630).
RH_CHAIN_RPC=https://rpc.testnet.chain.robinhood.com

# Etherscan API key (one key now covers Arbitrum via Etherscan V2).   [secret]
# Get it free at etherscan.io -> API Keys. Used by forge/cast verify.
ARBISCAN_API_KEY=
ETHERSCAN_API_KEY=

# ======================================================================
# Deployer + multisig
# ======================================================================
# [secret] Testnet-only deployer EOA. NEVER use on mainnet, NEVER commit.
# The .env.example default below is the Hardhat/Anvil well-known key (local
# fork dev only), carved out by .gitleaksignore.
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# [public] Praetor multisig address. Year-1 this is the deployer EOA; the
# 3-of-5 Safe migration switches it later.
PRAETOR_MULTISIG_ADDRESS=
# [secret] Praetor signing key for services that submit praetor txs
# (Sumsub callback -> Edict.assignTier, chaos pause/restore). Year-1 == the
# deployer key.
PRAETOR_MULTISIG_KEY=

# ======================================================================
# Account abstraction (Pimlico + Postern)                      [optional]
# ======================================================================
PIMLICO_API_KEY=
PIMLICO_RPC_URL=

# ======================================================================
# Codex API (x402 + HMAC)
# ======================================================================
COINBASE_X402_API_URL=https://facilitator.coinbase.com/x402
COINBASE_X402_API_KEY=                 # [secret] Coinbase x402 facilitator
CODEX_HMAC_KEY=                        # [genned] response-signing HMAC
CODEX_KEY_ID=v1
# [public] x402 payment routing. Must NOT be the leaked deployer EOA on a
# real deploy; point at the multisig recipient. Blank surfaces a loud 503.
CODEX_PAY_TO_ADDRESS=
CODEX_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
CODEX_MIN_PAYMENT_USDC_WEI=1000000
CODEX_URL=                             # [public] deployed codex base URL
# [secret] Upstash Redis REST for durable x402 replay-dedup + idempotency.
# Free tier at upstash.com -> Create Database (Redis) -> copy REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
DATABASE_URL=postgres://atrium:atrium@localhost:5432/atrium  # [optional] alt deploy
# [optional] Per-IP API rate limits (requests/min). Method-aware: reads get a
# generous bucket (the polling dashboard fires many parallel GETs and a shared
# demo-venue IP must not throttle itself); writes stay tight for spam control.
# Raise RATE_LIMIT_READ_PER_MIN before a live demo with a large shared-IP crowd.
RATE_LIMIT_READ_PER_MIN=600
RATE_LIMIT_WRITE_PER_MIN=60

# ======================================================================
# Notifier service
# ======================================================================
ATRIUM_INTERNAL_KEY=                   # [genned] prefs-API -> notifier bearer
NOTIFIER_INTERNAL_KEY=                 # [genned] same handshake, must match
ATRIUM_KV_REST_URL=                    # [secret] Upstash (same instance as above)
ATRIUM_KV_REST_TOKEN=
NOTIFIER_FROM_BLOCK=0
SCRIBE_URL=                            # [public] subgraph query URL (see NEXT_PUBLIC_SCRIBE_URL)
PREFS_API_URL=                         # [public] https://useatrium.me/api/settings/notifications

# ======================================================================
# Lantern attestor (proof of reserves)
# ======================================================================
LANTERN_KEY_PATH=./secrets/lantern.key.enc
LANTERN_KEY_PASSPHRASE=                 # [secret]
LANTERN_CRON_SECRET=                    # [genned] protects /api/cron from public hits
PINATA_JWT=                            # [secret] Pinata JWT; without it the Lantern Merkle tree is not IPFS-pinned (the on-chain root still publishes + shows, only inclusion-verify needs the pinned tree)

# ======================================================================
# Sumsub KYC webhook + Edict                                   [optional]
# ======================================================================
SUMSUB_WEBHOOK_SECRET=                  # [secret] Sumsub dashboard. Blank -> 503 not_configured.
EDICT_CONTRACT_ADDR=                    # [public] from deployments/arbitrum_sepolia.json

# ======================================================================
# Chaos drill (Verifier Mode step 4)                           [optional]
# ======================================================================
CHAOS_PRIVATE_KEY=                      # [secret] EOA with multisig privileges (year-1 == deployer)
CHAOS_DEMO_KEEPER=                      # [public] keeper-to-mark address; blank uses chaos signer
CHAOS_DRILL_KEY=                        # [genned] auth for the chaos drill route

# ======================================================================
# Demo session / multi-tenant default
# ======================================================================
# [public] Default demo wallet when no ?wallet= is present. FAIL-CLOSED in
# production: never fires unless ATRIUM_ALLOW_DEMO_SESSION=true is also set.
DEMO_WALLET_ADDRESS=
DEMO_WALLET_ENS=
ATRIUM_ALLOW_DEMO_SESSION=              # leave blank/false on any real deploy
ATRIUM_SESSION_SECRET=                  # [genned] signs the demo session cookie
ATRIUM_AUTH_HOST=                       # [optional] override auth host
ATRIUM_ALLOWED_PREVIEW_REGEX=           # [optional] preview-deploy origin allowlist
ATRIUM_DEPLOYMENTS_PATH=                # [optional] override the deployments JSON path

# ======================================================================
# The Graph + agents
# ======================================================================
GRAPH_STUDIO_DEPLOY_KEY=                # [secret] Subgraph Studio deploy key
FLY_API_TOKEN=                          # [secret] Fly.io agents (optional)
CRON_SECRET=                            # [genned] Vercel cron-only auth for agent ticks
AGENTS_URL=                             # [public] deployed agents service URL
# [public] Per-agent session-key EOAs (year-1 default to the deployer).
AGENT_AUGUR_ADDRESS=
AGENT_HARUSPEX_ADDRESS=
AGENT_AUSPEX_ADDRESS=

# ======================================================================
# Tablet                                                       [optional]
# ======================================================================
TABLET_URL=

# ======================================================================
# Testnet tokens (transfer UI)                                  [public]
# ======================================================================
# USDC falls back to Circle's Arb Sepolia USDC if unset. Others are optional
# (no canonical testnet USDT; LINK is Chainlink's Arb Sepolia LINK).
NEXT_PUBLIC_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
ARB_SEPOLIA_USDT=
ARB_SEPOLIA_LINK=0xb1D4538B4571d411F07960EF2838Ce337FE1E80E
RH_CHAIN_USDC=0x67713074650Ad05c832C781101Ac447Cb847522E
RH_CHAIN_USDT=
RH_CHAIN_LINK=

# ======================================================================
# Public-side (NEXT_PUBLIC_*), exposed to the browser bundle    [public]
# ======================================================================
# Subgraph query URL. Pin an explicit version; the /latest alias can lag.
NEXT_PUBLIC_SCRIBE_URL=https://api.studio.thegraph.com/query/1753863/atrium-arbitrum-sepolia/v0.0.15
NEXT_PUBLIC_SITE_URL=https://useatrium.me
NEXT_PUBLIC_ATRIUM_ADMIN_WALLETS=       # comma-separated admin addresses
NEXT_PUBLIC_LOADTEST_METRICS_URL=       # [optional] loadtest metrics endpoint
NEXT_PUBLIC_DEVCYCLE_CLIENT_KEY=        # [optional] feature flags
# E2E-only (Rabby + dappwright). Leave blank in normal runs.
NEXT_PUBLIC_E2E=
NEXT_PUBLIC_E2E_ADDRESS=
NEXT_PUBLIC_E2E_PRIVATE_KEY=

# ======================================================================
# Observability                                               [optional]
# ======================================================================
# Sentry: free at sentry.io -> create project -> copy DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_ENVIRONMENT=development
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=
NEXT_PUBLIC_NEW_RELIC_APP_ID=
NEXT_PUBLIC_NEW_RELIC_LICENSE_KEY=

# ======================================================================
# Misc                                                        [optional]
# ======================================================================
IPFS_GATEWAY=https://ipfs.io/ipfs/
KANI_STATUS_URL=                        # CI Kani-proof status artifact URL
FEEDBACK_WEBHOOK_URL=                   # Discord/Slack webhook for in-app feedback
LT_USERNAME=                            # loadtest (k6 cloud) creds
LT_ACCESS_KEY=
VERCEL_PROJECT_PRODUCTION_URL=          # set automatically on Vercel

# ======================================================================
# Cloudflare (Codex on Workers)                               [secret]
# ======================================================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
