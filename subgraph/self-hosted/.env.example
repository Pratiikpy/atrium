# Copy to .env and fill in. The real .env is gitignored — never commit secrets.

# REQUIRED: strong random password for the graph-node postgres.
#   generate:  openssl rand -hex 24
POSTGRES_PASSWORD=

# Archive RPC for Arbitrum Sepolia. The public node works but backfills slowly;
# an Alchemy/Infura free-tier ARCHIVE RPC is far faster for the ~5M-block sync.
ETHEREUM_RPC=https://arbitrum-sepolia.publicnode.com
